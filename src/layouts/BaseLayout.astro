---
import '../styles/globals.css';
import '@fontsource/dm-serif-display/400.css';
import '@fontsource/dm-serif-display/400-italic.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE, siteUrl } from '../config/site.mjs';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  hideNav?: boolean;
  hideTopBar?: boolean;
}

const { title, description, ogImage, ogType, hideNav, hideTopBar } = Astro.props;
const defaultDesc = SITE.description;
const absTitle = `${title} — Baixin Guo`;
const absDesc = description || defaultDesc;
const ogImageUrl = siteUrl(ogImage || '/og-default.svg');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{absTitle}</title>
    <meta name="description" content={absDesc} />

    <!-- Open Graph -->
    <meta property="og:title" content={absTitle} />
    <meta property="og:description" content={absDesc} />
    <meta property="og:type" content={ogType || 'website'} />
    <meta property="og:url" content={Astro.url} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={absTitle} />
    <meta name="twitter:description" content={absDesc} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url} />

    <!-- Schema.org Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Baixin Guo",
      "givenName": "Baixin",
      "familyName": "Guo",
      "email": "gbx1220max@gmail.com",
      "url": SITE.url,
      "sameAs": [
        "https://github.com/GBX-Max1220",
        "https://www.linkedin.com/in/baixin-guo-681113285/",
      ],
      "description": defaultDesc,
    })}></script>

    <!-- Fonts: self-hosted via @fontsource -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Baixin Guo — Blog" href="/rss.xml" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <!-- Top contact bar -->
    {!hideTopBar && <div class="bg-[var(--color-page-warm)] border-b border-[var(--color-rule-light)]">
      <div class="container-content flex items-center justify-center sm:justify-end gap-5 sm:gap-6 h-9 text-[0.7rem]">
        <a href="https://github.com/GBX-Max1220" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="currentColor" class="flex-shrink-0">
            <path d="M9 0a9 9 0 0 0-2.84 17.54c.45.08.62-.2.62-.44v-1.56c-2.56.56-3.1-1.1-3.1-1.1-.42-1.07-1.03-1.35-1.03-1.35-.84-.57.06-.56.06-.56.93.07 1.42.96 1.42.96.82 1.41 2.16 1 2.69.77.08-.6.33-1.01.59-1.24-2.06-.24-4.22-1.03-4.22-4.58 0-1.01.36-1.84.95-2.48-.1-.24-.42-1.18.09-2.46 0 0 .78-.25 2.55.95a8.9 8.9 0 0 1 4.64 0c1.77-1.2 2.55-.95 2.55-.95.51 1.28.19 2.22.1 2.46.59.64.95 1.47.95 2.48 0 3.55-2.16 4.34-4.22 4.57.33.28.62.84.62 1.7v2.52c0 .24.16.52.63.44A9 9 0 0 0 9 0z"/>
          </svg>
          <span class="hidden sm:inline">GBX-Max1220</span>
        </a>
        <a href="https://www.linkedin.com/in/baixin-guo-681113285/" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="currentColor" class="flex-shrink-0">
            <path d="M4 6h2.5v7.5H4V6zm1.2-1.1a1.4 1.4 0 1 1 0-2.8 1.4 1.4 0 0 1 0 2.8zM8.7 6h2.4v1.1h0A3 3 0 0 1 13.8 5.5c2.6 0 3.1 1.7 3.1 4v4h-2.5v-3.5c0-1.1 0-2.4-1.5-2.4s-1.7 1.2-1.7 2.4V13.5H8.7V6z"/>
          </svg>
          <span class="hidden sm:inline">Baixin Guo</span>
        </a>
        <a href="mailto:gbx1220max@gmail.com" class="flex items-center gap-1.5 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
            <rect x="2" y="4" width="14" height="10" rx="2"/>
            <path d="M2 6l7 5 7-5"/>
          </svg>
          <span class="hidden sm:inline">gbx1220max@gmail.com</span>
        </a>
        <a href="/contact/" class="flex items-center gap-1.5 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
            <path d="M17.5 8.5a4 4 0 0 1 3.5 3.5c0 2.2-1.8 4-4 4H14l-3 2v-2h-.5a4 4 0 0 1-3.5-5" stroke="currentColor" fill="none"/>
            <path d="M6.5 3.5A4 4 0 0 0 3 7c0 2.2 1.8 4 4 4H8l2 1.5v-1.5h.5a4 4 0 0 0 3-3.5" stroke="currentColor" fill="none"/>
            <circle cx="7" cy="8" r="0.8" fill="currentColor" stroke="none"/>
            <circle cx="9.5" cy="8" r="0.8" fill="currentColor" stroke="none"/>
            <circle cx="14" cy="10.5" r="0.8" fill="currentColor" stroke="none"/>
            <circle cx="16.5" cy="10.5" r="0.8" fill="currentColor" stroke="none"/>
          </svg>
          <span>WeChat</span>
        </a>
      </div>
    </div>}
    {!hideNav && <Nav />}
    <main id="main-content">
      <slot />
    </main>
    <Footer />

  <!-- Back to top -->
  <button onclick="window.scrollTo({top:0,behavior:'smooth'})" class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-[var(--color-primary)] text-white shadow-lg flex items-center justify-center opacity-0 translate-y-4 transition-all duration-300 hover:bg-[var(--color-primary-dim)]" id="back-to-top" aria-label="Back to top">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 13V3M3 8l5-5 5 5"/></svg>
  </button>
  <script>document.addEventListener('DOMContentLoaded',()=>{const b=document.getElementById('back-to-top');if(b){window.addEventListener('scroll',()=>{const s=window.scrollY>300;b.style.opacity=s?'1':'0';b.style.transform=s?'translateY(0)':'translateY(1rem)';b.style.pointerEvents=s?'auto':'none'})}})</script>
</body>
</html>
