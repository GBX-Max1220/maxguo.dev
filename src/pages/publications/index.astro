---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Publications" description="Research publications — Baixin Guo">
  <div class="container-content py-16">
    <div class="max-w-2xl">

      <span class="section-label mb-4">Publications</span>
      <h1 class="mb-8">Publications</h1>

      <!-- Featured -->
      <h2 class="text-[1.15rem] mb-5 font-sans font-semibold text-[var(--color-ink)]">Featured</h2>

      <div class="space-y-4 mb-12">

        <!-- Paper 1 -->
        <div class="card" id="checkmycoach-paper">
          <div class="flex items-center gap-3 mb-3">
            <span class="badge badge-under-review">Under Review</span>
            <span class="font-mono text-[0.6rem] text-[var(--color-text-muted)]">CSCW 2027</span>
          </div>
          <h3 class="font-display text-[1.1rem] text-[var(--color-ink)] mb-1">From Precision Illusion to Calibration Intervention</h3>
          <p class="font-mono text-[0.65rem] text-[var(--color-text-dim)] mb-2">Baixin Guo. 2026.</p>
          <p class="text-sm text-[var(--color-text-dim)] leading-relaxed mb-4">
            LLM calibration framework + CheckMyCoach pipeline for correcting uncertainty expression in safety-critical advice.
          </p>
          <div class="flex flex-wrap gap-2">
            <a href="/research/building-trustworthy-ai/checkmycoach/" class="btn btn-primary btn-sm">
              Project
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 5h6M5 2l3 3-3 3"/>
              </svg>
            </a>
            <span class="btn btn-sm opacity-60 cursor-default">arXiv — ID pending</span>
          </div>
        </div>

        <!-- Paper 2 -->
        <div class="card" id="fitcalib-bench-paper">
          <div class="flex items-center gap-3 mb-3">
            <span class="badge badge-published">In Preparation</span>
          </div>
          <h3 class="font-display text-[1.1rem] text-[var(--color-ink)] mb-1">MaxFitCalib-Bench: A Benchmark for LLM Calibration</h3>
          <p class="font-mono text-[0.65rem] text-[var(--color-text-dim)] mb-2">Baixin Guo. 2026.</p>
          <p class="text-sm text-[var(--color-text-dim)] leading-relaxed mb-4">
            126-question benchmark for evaluating LLM calibration in fitness advice, revealing the precision illusion.
          </p>
          <div class="flex flex-wrap gap-2">
            <a href="/research/measuring-ai-reliability/fitcalib-bench/" class="btn btn-primary btn-sm">
              Project
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 5h6M5 2l3 3-3 3"/>
              </svg>
            </a>
            <span class="btn btn-sm opacity-60 cursor-default">arXiv — ID pending</span>
          </div>
        </div>

      </div>

      <!-- All Publications -->
      <h2 class="text-[1.15rem] mb-5 font-sans font-semibold text-[var(--color-ink)]">All Publications</h2>

      <div class="card-static divide-y divide-[var(--color-rule-light)]">
        <div class="pub-entry">
          <div>
            <span class="badge badge-under-review text-[0.55rem] mb-2">Under Review</span>
            <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)] ml-2">CSCW 2027</span>
            <p class="font-medium text-[var(--color-ink)] text-sm mt-1">From Precision Illusion to Calibration Intervention</p>
            <p class="text-xs text-[var(--color-text-dim)]">Baixin Guo. 2026.</p>
          </div>
          <div class="hidden sm:block text-right">
            <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)]">in review</span>
          </div>
        </div>
        <div class="pub-entry">
          <div>
            <span class="badge badge-published text-[0.55rem] mb-2">In Preparation</span>
            <p class="font-medium text-[var(--color-ink)] text-sm mt-1">MaxFitCalib-Bench: A Benchmark for LLM Calibration in Fitness Advice</p>
            <p class="text-xs text-[var(--color-text-dim)]">Baixin Guo. 2026.</p>
          </div>
          <div class="hidden sm:block text-right">
            <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)]">in prep</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
