---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationStatus from '../../components/PublicationStatus.astro';
import { projectHref, publicationStatusMeta } from '../../lib/publications';

const publications = (await getCollection('publication')).sort((a, b) =>
  b.data.year - a.data.year || a.data.title.localeCompare(b.data.title)
);
const featured = publications.filter(({ data }) => data.featured);

const venueLabel = (publication) => {
  if (publication.venue) return publication.venue;
  if (!publication.venueTarget) return '';
  return publication.status === 'submitted'
    ? `Submitted to ${publication.venueTarget}`
    : `Target: ${publication.venueTarget}`;
};
---

<BaseLayout title="Publications" description="Research publications — Baixin Guo">
  <div class="container-content py-16">
    <div class="max-w-2xl">

      <span class="section-label mb-4">Publications</span>
      <h1 class="mb-8">Publications</h1>

      <h2 class="text-[1.15rem] mb-5 font-sans font-semibold text-[var(--color-ink)]">Featured</h2>

      <div class="space-y-4 mb-12">
        {featured.map(({ id, data }) => {
          const projectUrl = projectHref(data.projectId);
          const venue = venueLabel(data);
          return (
            <article class="card" id={id}>
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <PublicationStatus status={data.status} />
                {venue && <span class="font-mono text-[0.6rem] text-[var(--color-text-muted)]">{venue}</span>}
              </div>
              <h3 class="font-display text-[1.1rem] text-[var(--color-ink)] mb-1">{data.title}</h3>
              <p class="font-mono text-[0.65rem] text-[var(--color-text-dim)] mb-2">{data.authors.join(', ')}. {data.year}.</p>
              {data.abstract && <p class="text-sm text-[var(--color-text-dim)] leading-relaxed mb-4">{data.abstract}</p>}
              <div class="flex flex-wrap gap-2">
                {projectUrl && <a href={projectUrl} class="btn btn-primary btn-sm">Project →</a>}
                {data.links.arxiv && <a href={data.links.arxiv} class="btn btn-sm" target="_blank" rel="noopener">arXiv</a>}
                {data.links.preprint && <a href={data.links.preprint} class="btn btn-sm" target="_blank" rel="noopener">Preprint</a>}
                {data.links.pdf && <a href={data.links.pdf} class="btn btn-sm" target="_blank" rel="noopener">PDF</a>}
                {data.links.code && <a href={data.links.code} class="btn btn-sm" target="_blank" rel="noopener">Code</a>}
                {data.links.dataset && <a href={data.links.dataset} class="btn btn-sm" target="_blank" rel="noopener">Data</a>}
              </div>
            </article>
          );
        })}
      </div>

      <h2 class="text-[1.15rem] mb-5 font-sans font-semibold text-[var(--color-ink)]">All Publications</h2>

      <div class="card-static divide-y divide-[var(--color-rule-light)]">
        {publications.map(({ id, data }) => {
          const meta = publicationStatusMeta(data.status);
          const venue = venueLabel(data);
          return (
            <div class="pub-entry" id={`all-${id}`}>
              <div>
                <PublicationStatus status={data.status} class="text-[0.55rem] mb-2" />
                {venue && <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)] ml-2">{venue}</span>}
                <p class="font-medium text-[var(--color-ink)] text-sm mt-1">{data.title}</p>
                <p class="text-xs text-[var(--color-text-dim)]">{data.authors.join(', ')}. {data.year}.</p>
              </div>
              <div class="hidden sm:block text-right">
                <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)]">{meta.shortLabel}</span>
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </div>
</BaseLayout>
