---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const pubs = await getCollection('publication');
  return pubs.map((pub) => ({
    params: { id: pub.data.id },
    props: { pub },
  }));
}

const { pub } = Astro.props;
const { data } = pub;
---

<BaseLayout title={data.title} description={data.abstract || data.title}>
  <div class="container-content py-16">
    <div class="max-w-2xl">

      <a href="/publications/" class="link-arrow mb-6 inline-flex">
        &larr; All publications
      </a>

      <!-- Status badge -->
      <div class="flex items-center gap-3 mb-4">
        {data.status === 'under_review' && <span class="badge badge-under-review">Under Review</span>}
        {data.status === 'preprint' && <span class="badge badge-published">Preprint</span>}
        {data.status === 'published' && <span class="badge badge-published">Published</span>}
        <span class="font-mono text-[0.6rem] text-[var(--color-text-muted)]">{data.venue}</span>
        <span class="font-mono text-[0.6rem] text-[var(--color-text-muted)]">{data.year}</span>
      </div>

      <h1 class="mb-3">{data.title}</h1>
      <p class="text-sm text-[var(--color-text-dim)] mb-6">{data.authors.join(', ')}. {data.year}.</p>

      <!-- Abstract -->
      {data.abstract && (
        <div class="card-static mb-6">
          <h2 class="font-sans text-[0.7rem] font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Abstract</h2>
          <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">{data.abstract}</p>
        </div>
      )}

      <!-- Citation buttons -->
      <div class="card-static mb-6">
        <h2 class="font-sans text-[0.7rem] font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Cite</h2>
        <div class="space-y-2">
          {['bibtex', 'apa', 'chicago', 'mla'].map((style) => (
            <div class="flex items-start gap-2">
              <button
                class="btn btn-sm flex-shrink-0 text-[0.55rem]"
                onclick={`
                  var t = this.nextElementSibling;
                  navigator.clipboard.writeText(t.textContent);
                  var o = this.textContent;
                  this.textContent = 'Copied!';
                  setTimeout(() => { this.textContent = o; }, 1500);
                `}
              >Copy</button>
              <code class="text-xs text-[var(--color-text-dim)] bg-[var(--color-page-alt)] rounded px-2 py-1.5 flex-1 overflow-x-auto">
                {data.citation[style]}
              </code>
            </div>
          ))}
        </div>
      </div>

      <!-- Links -->
      {data.links && (
        <div class="card-static mb-6">
          <h2 class="font-sans text-[0.7rem] font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Links</h2>
          <div class="flex flex-wrap gap-2">
            {data.links.arxiv && <a href={data.links.arxiv} class="btn btn-sm" target="_blank">arXiv</a>}
            {data.links.pdf && <a href={data.links.pdf} class="btn btn-sm" target="_blank">PDF</a>}
            {data.links.doi && <a href={'https://doi.org/' + data.links.doi} class="btn btn-sm" target="_blank">DOI</a>}
            {data.links.code && <a href={data.links.code} class="btn btn-sm" target="_blank">Code</a>}
            {!data.links.arxiv && !data.links.pdf && !data.links.doi && !data.links.code && (
              <span class="text-xs text-[var(--color-text-muted)] italic">Links coming soon</span>
            )}
          </div>
        </div>
      )}

      <!-- Related project -->
      {data.projectId && (
        <div class="card-static mb-6 bg-[var(--color-page-warm)]">
          <h2 class="font-sans text-[0.7rem] font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Related Project</h2>
          <a href={'/research/building-trustworthy-ai/' + data.projectId + '/'} class="link-arrow">
            View project details &rarr;
          </a>
        </div>
      )}

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5">
        {data.tags.map((tag) => <span class="badge text-[0.55rem]">{tag}</span>)}
      </div>

    </div>
  </div>
</BaseLayout>
