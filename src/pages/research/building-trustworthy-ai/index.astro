---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Building Trustworthy AI" description="How should AI systems communicate uncertainty to humans?">
  <div class="container-content py-16">
    <div class="max-w-2xl">
      <a href="/research/" class="link-arrow mb-6 inline-flex">
        ← All research
      </a>
      <span class="section-label mb-4">Research Program</span>
      <h1 class="mb-4">Building Trustworthy AI</h1>
      <p class="text-base text-[var(--color-text-dim)] italic mb-2">Scientific Question:</p>
      <p class="text-lg font-display text-[var(--color-ink)] mb-6">How should AI systems communicate uncertainty to humans?</p>
      <div class="card-static mb-8">
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          This program designs and evaluates interaction techniques that help AI systems express calibrated uncertainty, enabling users to make better-informed decisions when relying on AI advice.
        </p>
      </div>
      <h2 class="font-sans text-[0.8rem] font-semibold text-[var(--color-text-dim)] uppercase tracking-wider mb-4">Projects</h2>
      <a href="/research/building-trustworthy-ai/checkmycoach/" class="card group block">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-6 h-6 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.5rem] font-bold">P</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Active</span>
        </div>
        <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors">CheckMyCoach</h3>
        <p class="text-sm text-[var(--color-text-dim)] mt-1">A Calibration Pipeline for LLM Uncertainty Expression</p>
      </a>
      <a href="/research/building-trustworthy-ai/knowledge-compiler/" class="card group block">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-6 h-6 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.5rem] font-bold">K</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Active</span>
        </div>
        <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors">Knowledge Compiler</h3>
        <p class="text-sm text-[var(--color-text-dim)] mt-1">Structured Knowledge Extraction from Textbooks</p>
      </a>
      <a href="/research/building-trustworthy-ai/interactionkit/" class="card group block">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-6 h-6 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.5rem] font-bold">I</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Active</span>
        </div>
        <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors">InteractionKit</h3>
        <p class="text-sm text-[var(--color-text-dim)] mt-1">A Methodological Infrastructure for HAI Trust Calibration</p>
      </a>
      <a href="/research/building-trustworthy-ai/pi-discovery/" class="card group block">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-6 h-6 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.5rem] font-bold">I</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Development</span>
        </div>
        <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors">PI Discovery Engine</h3>
        <p class="text-sm text-[var(--color-text-dim)] mt-1">From Research Topics to Investigator Cards</p>
      </a>
    </div>
  </div>
</BaseLayout>
