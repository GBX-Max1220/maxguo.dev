---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Understanding Human Trust in AI" description="How do people calibrate trust in AI systems?">
  <div class="container-content py-16">
    <div class="max-w-2xl">
      <a href="/research/" class="link-arrow mb-6 inline-flex">
        ← All research
      </a>
      <span class="section-label mb-4">Research Program</span>
      <h1 class="mb-4">Understanding Human Trust in AI</h1>
      <p class="text-base text-[var(--color-text-dim)] italic mb-2">Scientific Question:</p>
      <p class="text-lg font-display text-[var(--color-ink)] mb-6">How do people calibrate trust in AI systems?</p>
      <div class="card-static mb-8">
        <p class="text-sm text-[var(--color-text-dim)] leading-relaxed">
          This program studies the cognitive and behavioral mechanisms through which users form, maintain, and adjust their trust in AI advisors across different domains and interaction paradigms.
        </p>
      </div>
      <h2 class="font-sans text-[0.8rem] font-semibold text-[var(--color-text-dim)] uppercase tracking-wider mb-4">Projects</h2>
      <a href="/research/understanding-human-trust/caltrust/" class="card group block">
        <div class="flex items-center gap-3 mb-2">
          <span class="w-6 h-6 rounded-full bg-[var(--color-gold-subtle)] flex items-center justify-center text-[var(--color-gold)] font-mono text-[0.5rem] font-bold">P</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Active</span>
        </div>
        <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors">CalTrust</h3>
        <p class="text-sm text-[var(--color-text-dim)] mt-1">Adaptive Trust Calibration via Contextual Bandits</p>
      </a>
    </div>
  </div>
</BaseLayout>
