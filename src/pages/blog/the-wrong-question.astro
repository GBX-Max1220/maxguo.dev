---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const post = posts.find(p => p.id === 'the-wrong-question');
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <div class="container-content py-16">
    <div class="max-w-2xl">

      <a href="/blog/" class="link-arrow mb-6 inline-flex">
        ← All posts
      </a>

      <div class="flex items-center gap-3 mb-4">
        <span class="badge badge-gold">Essay</span>
        <span class="font-mono text-[0.6rem] text-[var(--color-text-muted)]">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      </div>

      <h1 class="mb-3">{post.data.title}</h1>
      <p class="text-sm text-[var(--color-text-dim)] italic mb-6">{post.data.excerpt}</p>

      <div class="flex flex-wrap gap-1.5 mb-8">
        {post.data.tags.map((tag) => <span class="badge text-[0.55rem]">{tag}</span>)}
      </div>

      <div class="prose-page">
        <Content />
      </div>

    </div>
  </div>
</BaseLayout>
