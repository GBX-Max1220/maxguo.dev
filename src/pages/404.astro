---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Page Not Found" description="Page not found">
  <div class="container-content py-24">
    <div class="max-w-md mx-auto text-center">

      <div class="w-16 h-16 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center mx-auto mb-6">
        <span class="text-2xl font-display text-[var(--color-primary)]">404</span>
      </div>

      <h1 class="text-[1.8rem] mb-3">Page Not Found</h1>
      <p class="text-sm text-[var(--color-text-dim)] leading-relaxed mb-8">
        The page you're looking for doesn't exist — or has moved.
        Most of my research projects live under <strong>/research/</strong>.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/research/" class="btn">Research</a>
        <a href="/projects/" class="btn">Projects</a>
        <a href="/blog/" class="btn">Blog</a>
      </div>

    </div>
  </div>
</BaseLayout>
