---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Get in touch — Max Guo">
  <div class="container-content py-16">
    <div class="max-w-lg">

      <span class="section-label mb-4">Contact</span>
      <h1 class="mb-4">Get in Touch</h1>
      <p class="text-sm text-[var(--color-text-dim)] mb-8">
        Feel free to reach out for research discussions, collaboration opportunities, or questions about my work.
      </p>

      <div class="space-y-4">

        <!-- Email -->
        <div class="card-static flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="14" height="10" rx="2"/>
              <path d="M2 6l7 5 7-5"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-0.5">Email</p>
            <a href="mailto:gbx1220max@gmail.com" class="text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-primary)] transition-colors">gbx1220max@gmail.com</a>
          </div>
        </div>

        <!-- WeChat -->
        <div class="card-static flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.5 8.5a4 4 0 0 1 3.5 3.5c0 2.2-1.8 4-4 4H14l-3 2v-2h-.5a4 4 0 0 1-3.5-5" stroke="var(--color-secondary)" fill="none"/>
              <path d="M6.5 3.5A4 4 0 0 0 3 7c0 2.2 1.8 4 4 4H8l2 1.5v-1.5h.5a4 4 0 0 0 3-3.5" stroke="var(--color-secondary)" fill="none"/>
              <circle cx="7" cy="8" r="0.8" fill="var(--color-secondary)" stroke="none"/>
              <circle cx="9.5" cy="8" r="0.8" fill="var(--color-secondary)" stroke="none"/>
              <circle cx="14" cy="10.5" r="0.8" fill="var(--color-secondary)" stroke="none"/>
              <circle cx="16.5" cy="10.5" r="0.8" fill="var(--color-secondary)" stroke="none"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-0.5">WeChat</p>
            <p class="text-sm font-medium text-[var(--color-ink)]">Max-GuoBX</p>
          </div>
        </div>

        <!-- GitHub -->
        <div class="card-static flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-ink-light)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="var(--color-surface)">
              <path d="M9 0a9 9 0 0 0-2.84 17.54c.45.08.62-.2.62-.44v-1.56c-2.56.56-3.1-1.1-3.1-1.1-.42-1.07-1.03-1.35-1.03-1.35-.84-.57.06-.56.06-.56.93.07 1.42.96 1.42.96.82 1.41 2.16 1 2.69.77.08-.6.33-1.01.59-1.24-2.06-.24-4.22-1.03-4.22-4.58 0-1.01.36-1.84.95-2.48-.1-.24-.42-1.18.09-2.46 0 0 .78-.25 2.55.95a8.9 8.9 0 0 1 4.64 0c1.77-1.2 2.55-.95 2.55-.95.51 1.28.19 2.22.1 2.46.59.64.95 1.47.95 2.48 0 3.55-2.16 4.34-4.22 4.57.33.28.62.84.62 1.7v2.52c0 .24.16.52.63.44A9 9 0 0 0 9 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-0.5">GitHub</p>
            <a href="https://github.com/GBX-Max1220" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-primary)] transition-colors">GBX-Max1220</a>
          </div>
        </div>

        <!-- LinkedIn -->
        <div class="card-static flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="var(--color-primary)">
              <path d="M4 6h2.5v7.5H4V6zm1.2-1.1a1.4 1.4 0 1 1 0-2.8 1.4 1.4 0 0 1 0 2.8zM8.7 6h2.4v1.1h0A3 3 0 0 1 13.8 5.5c2.6 0 3.1 1.7 3.1 4v4h-2.5v-3.5c0-1.1 0-2.4-1.5-2.4s-1.7 1.2-1.7 2.4V13.5H8.7V6z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-0.5">LinkedIn</p>
            <a href="https://www.linkedin.com/in/baixin-guo-681113285/" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-primary)] transition-colors">Baixin Guo</a>
          </div>
        </div>

        <!-- ResearchGate -->
        <div class="card-static flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="var(--color-secondary)">
              <path d="M4 4h10v2H9v3H7V6H4V4zm0 5h3v5H4V9zm5-1h2v6H9V8zm3 0h2v6h-2V8z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-0.5">ResearchGate</p>
            <a href="https://www.researchgate.net/profile/Baixin-Guo-2" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-primary)] transition-colors">Baixin Guo</a>
          </div>
        </div>

        <!-- Social -->
        <div class="card-static">
          <p class="text-xs font-mono text-[var(--color-text-muted)] uppercase tracking-wider mb-3">Social</p>
          <div class="flex flex-wrap gap-2">
            <a href="https://orcid.org/0009-0008-3661-9530" target="_blank" rel="noopener" class="btn btn-sm">ORCID</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
