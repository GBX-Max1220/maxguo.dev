---
import BaseLayout from '../layouts/BaseLayout.astro';
import ActivityLog from '../components/ActivityLog.astro';
const site = 'https://maxguo.dev';
---

<BaseLayout title="Home" description="LLM Calibration & Trust in AI Coaching | Max Guo" ogImage="/og/home.png" hideNav hideTopBar>

<!-- ================================================================ -->
<!-- TWO-COLUMN LAYOUT: Left = brand sidebar, Right = content flow    -->
<!-- ================================================================ -->
<div class="container-content">
  <div class="flex flex-col lg:flex-row gap-0 lg:gap-16">

    <!-- ============================================================ -->
    <!-- LEFT COLUMN —?personal brand sidebar (sticky on lg+)          -->
    <!-- ============================================================ -->
    <div class="w-full lg:w-[340px] lg:min-w-[340px] lg:sticky lg:top-20 lg:self-start py-12 lg:py-20">

      <!-- Navigation (placed in sidebar, not top bar) -->
      <nav class="flex flex-wrap lg:flex-col gap-2 mb-10" aria-label="Section navigation">
        <a href="#research" class="group flex items-center gap-2 px-3 py-2 text-[0.8rem] font-mono font-medium uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-primary)] transition-colors rounded-md hover:bg-[var(--color-primary-subtle)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] opacity-40 group-hover:opacity-100 transition-opacity"></span>
          Research
        </a>
        <a href="/publications/" class="group flex items-center gap-2 px-3 py-2 text-[0.8rem] font-mono font-medium uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-primary)] transition-colors rounded-md hover:bg-[var(--color-primary-subtle)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity"></span>
          Publications
        </a>
        <a href="/blog/" class="group flex items-center gap-2 px-3 py-2 text-[0.8rem] font-mono font-medium uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-primary)] transition-colors rounded-md hover:bg-[var(--color-primary-subtle)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity"></span>
          Blog
        </a>
        <a href="/about/" class="group flex items-center gap-2 px-3 py-2 text-[0.8rem] font-mono font-medium uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-primary)] transition-colors rounded-md hover:bg-[var(--color-primary-subtle)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity"></span>
          About
        </a>
        <a href="/cv/" class="group flex items-center gap-2 px-3 py-2 text-[0.8rem] font-mono font-medium uppercase tracking-wider text-[var(--color-text-dim)] hover:text-[var(--color-primary)] transition-colors rounded-md hover:bg-[var(--color-primary-subtle)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity"></span>
          CV
        </a>
      </nav>

      <!-- Avatar + Contact Info -->
      <div class="flex items-start gap-5 mb-8">
        <!-- Avatar placeholder — replace src with your photo -->
        <div class="rounded-full flex-shrink-0 overflow-hidden bg-[var(--color-page-warm)] border-2 border-[var(--color-rule)]" style="width:48px;height:48px">
          <svg viewBox="0 0 100 100" fill="none" class="w-full h-full">
            <circle cx="50" cy="50" r="50" fill="var(--color-page-warm)"/>
            <circle cx="50" cy="38" r="16" fill="var(--color-primary-subtle)"/>
            <path d="M18 82c0-12 14-22 32-22s32 10 32 22" stroke="var(--color-primary-subtle)" stroke-width="3" fill="none"/>
            <text x="50" y="52" text-anchor="middle" font-family="'DM Serif Display', Georgia, serif" font-size="28" fill="var(--color-primary)" font-style="italic" dominant-baseline="central">M</text>
          </svg>
        </div>
        <!-- Contact info -->
        <div class="flex flex-col gap-2.5">
          <a href="https://github.com/GBX-Max1220" target="_blank" rel="noopener" class="flex items-center gap-2 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium text-sm">
            <svg width="20" height="20" viewBox="0 0 18 18" fill="currentColor" class="flex-shrink-0">
              <path d="M9 0a9 9 0 0 0-2.84 17.54c.45.08.62-.2.62-.44v-1.56c-2.56.56-3.1-1.1-3.1-1.1-.42-1.07-1.03-1.35-1.03-1.35-.84-.57.06-.56.06-.56.93.07 1.42.96 1.42.96.82 1.41 2.16 1 2.69.77.08-.6.33-1.01.59-1.24-2.06-.24-4.22-1.03-4.22-4.58 0-1.01.36-1.84.95-2.48-.1-.24-.42-1.18.09-2.46 0 0 .78-.25 2.55.95a8.9 8.9 0 0 1 4.64 0c1.77-1.2 2.55-.95 2.55-.95.51 1.28.19 2.22.1 2.46.59.64.95 1.47.95 2.48 0 3.55-2.16 4.34-4.22 4.57.33.28.62.84.62 1.7v2.52c0 .24.16.52.63.44A9 9 0 0 0 9 0z"/>
            </svg>
            GBX-Max1220
          </a>
          <a href="https://www.linkedin.com/in/baixin-guo-681113285/" target="_blank" rel="noopener" class="flex items-center gap-2 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium text-sm">
            <svg width="20" height="20" viewBox="0 0 18 18" fill="currentColor" class="flex-shrink-0">
              <path d="M4 6h2.5v7.5H4V6zm1.2-1.1a1.4 1.4 0 1 1 0-2.8 1.4 1.4 0 0 1 0 2.8zM8.7 6h2.4v1.1h0A3 3 0 0 1 13.8 5.5c2.6 0 3.1 1.7 3.1 4v4h-2.5v-3.5c0-1.1 0-2.4-1.5-2.4s-1.7 1.2-1.7 2.4V13.5H8.7V6z"/>
            </svg>
            Baixin Guo
          </a>
          <a href="mailto:gbx1220max@gmail.com" class="flex items-center gap-2 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium text-sm">
            <svg width="20" height="20" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
              <rect x="2" y="4" width="14" height="10" rx="2"/>
              <path d="M2 6l7 5 7-5"/>
            </svg>
            gbx1220max@gmail.com
          </a>
          <a href="/contact/" class="flex items-center gap-2 text-[var(--color-text-dim)] hover:text-[var(--color-ink)] transition-colors font-mono font-medium text-sm">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
              <path d="M17.5 8.5a4 4 0 0 1 3.5 3.5c0 2.2-1.8 4-4 4H14l-3 2v-2h-.5a4 4 0 0 1-3.5-5" stroke="currentColor" fill="none"/>
              <path d="M6.5 3.5A4 4 0 0 0 3 7c0 2.2 1.8 4 4 4H8l2 1.5v-1.5h.5a4 4 0 0 0 3-3.5" stroke="currentColor" fill="none"/>
              <circle cx="7" cy="8" r="0.8" fill="currentColor" stroke="none"/>
              <circle cx="9.5" cy="8" r="0.8" fill="currentColor" stroke="none"/>
              <circle cx="14" cy="10.5" r="0.8" fill="currentColor" stroke="none"/>
              <circle cx="16.5" cy="10.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
            Max-GuoBX
          </a>
        </div>
      </div>

      <!-- Name + identity -->
      <h1 class="font-display text-[2.4rem] leading-[1.05] text-[var(--color-ink)] mb-1">
        Max&nbsp;<span class="italic text-[var(--color-primary)]">Guo</span>
      </h1>
      <p class="font-mono text-sm text-[var(--color-text-dim)] mb-1">郭佰昕—?/ˈbaɪ.ʃiːn ˈɡwoʊ/ · bye-sheen gwoh</p>
      <p class="font-mono text-[0.65rem] text-[var(--color-primary)] font-medium uppercase tracking-[0.12em] mb-4">
        HCI &amp; AI Research · Applied Psychology
      </p>
      <p class="font-sans text-base text-[var(--color-text-dim)] leading-relaxed mb-6">
        I study how AI systems <span class="text-[var(--color-ink)] font-medium">mislead through false precision</span> — and build the methods to measure, fix, and prevent it.
      </p>
      <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-6">
        My work defines <strong class="text-[var(--color-ink)]">Precision Illusion</strong> — where AI sounds more certain than evidence warrants — and builds the full research stack to address it: from theory and measurement (MaxFitCalib-Bench) through intervention (CheckMyCoach) and adaptation (CalTrust), to infrastructure for reproducible experiments (Knowledge Compiler, InteractionKit).
      </p>
      <p class="font-mono text-[0.65rem] text-[var(--color-primary)] leading-relaxed mb-6">
        Application domain: fitness coaching. Extending to medicine &amp; law.
      </p>

      <!-- CTA -->
      <div class="flex flex-wrap gap-3 mb-6">
        <a href="#research" class="btn btn-primary text-base px-5 py-2.5">
          Explore my work
          <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </a>
        <a href="/about/" class="btn text-base px-5 py-2.5">
          About me
        </a>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="badge text-[0.7rem]">LLM Calibration</span>
        <span class="badge text-[0.7rem]">Trust in AI</span>
        <span class="badge badge-gold text-[0.7rem]">Sports × HCI</span>
        <span class="badge text-[0.7rem]">CSCW</span>
      </div>

      <!-- Divider -->
      <div class="divider-ornament mb-8"></div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-x-6 gap-y-4">
        <div>
          <div class="stat-number text-[1.6rem]">10–70×</div>          <div class="stat-label">FP reduction vs heuristic</div>
        </div>
        <div>
          <div class="stat-number text-[1.6rem]">3,904</div>          <div class="stat-label">Knowledge objects (2 textbooks)</div>
        </div>
        <div>
          <div class="stat-number text-[1.6rem]">+0.75</div>
          <div class="stat-label">UCS improvement (1–7 scale)</div>
        </div>
        <div>
          <div class="stat-number text-[1.6rem]">19.2K</div>
          <div class="stat-label">Simulation trials (LinUCB)</div>
        </div>
      </div>

      <!-- Impact statement -->
      <div class="mt-6 pt-5 border-t border-[var(--color-rule-light)]">
        <p class="font-sans text-[0.7rem] text-[var(--color-text-dim)] leading-relaxed italic">
          This work proposes a shift in AI evaluation: from measuring accuracy alone, to measuring how uncertainty is communicated and trusted.
        </p>
      </div>

    </div>

    <!-- ============================================================ -->
    <!-- RIGHT COLUMN —?content flow                                   -->
    <!-- ============================================================ -->
    <div class="flex-1 min-w-0 py-12 lg:py-20">

      <!-- Home hero banner -->
      <div class="mb-10 rounded-xl overflow-hidden border border-[var(--color-rule-light)]">
        <img src="/images/home-hero.png" alt="Precision Illusion — From Theory to Infrastructure" width="1200" height="500" class="w-full h-auto" loading="eager" />
      </div>

      <!-- RESEARCH ARC -->
      <section id="research" class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-7 h-7 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.65rem] font-bold">01</span>
          <span class="font-mono text-[0.6rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Research Arc</span>
        </div>
        <h2 class="text-[1.6rem] mb-2">Research Program</h2>
        <p class="font-sans text-sm text-[var(--color-text-dim)] mb-8 max-w-md">
          A five-layer research stack: from defining the Precision Illusion, to measuring and fixing it, to adapting interventions and building infrastructure.
        </p>

        <div class="space-y-4">
          <!-- Layer 1: Theory -->
          <div class="card group overflow-hidden">
            <img src="/images/projects/pi-discovery-hero.png" alt="" class="w-full h-28 object-cover" style="margin:-1.5rem -1.5rem 1rem -1.5rem; width:calc(100% + 3rem); max-width:none" loading="lazy" />
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-ink-light)] flex items-center justify-center text-[var(--color-surface)] font-mono text-[0.55rem] font-bold">01</span>
              <span class="font-mono text-[0.55rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Theory</span>
            </div>
            <h3 class="text-[1.05rem] mb-2">Precision Illusion Taxonomy</h3>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-3">
              Defining and taxonomizing how AI systems misrepresent uncertainty — from pseudo-precise numerical claims to unwarranted overconfidence. The foundation for all measurement and intervention work.
            </p>
            <a href="/research/building-trustworthy-ai/pi-discovery/" class="link-arrow">PI Taxonomy →</a>
          </div>

          <!-- Layer 2: Measurement -->
          <div class="card group overflow-hidden">
            <img src="/images/projects/fitcalib-bench-hero.png" alt="" class="w-full h-28 object-cover" style="margin:-1.5rem -1.5rem 1rem -1.5rem; width:calc(100% + 3rem); max-width:none" loading="lazy" />
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center text-[var(--color-secondary)] font-mono text-[0.55rem] font-bold">02</span>
              <span class="font-mono text-[0.55rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Measurement</span>
            </div>
            <h3 class="text-[1.05rem] mb-2">MaxFitCalib-Bench</h3>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-3">
              126-question benchmark revealing the precision illusion. Existing heuristic estimates <strong class="text-[var(--color-ink)]">overestimate fabrications by 10–70×</strong>. Built a replicable evidence verification pipeline.
            </p>
            <a href="/research/measuring-ai-reliability/fitcalib-bench/" class="link-arrow">Calibration Benchmark →</a>
          </div>

          <!-- Layer 3: Intervention -->
          <div class="card group overflow-hidden">
            <img src="/images/projects/checkmycoach-hero.png" alt="" class="w-full h-28 object-cover" style="margin:-1.5rem -1.5rem 1rem -1.5rem; width:calc(100% + 3rem); max-width:none" loading="lazy" />
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.55rem] font-bold">03</span>
              <span class="font-mono text-[0.55rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Intervention</span>
            </div>
            <h3 class="text-[1.05rem] mb-2">CheckMyCoach</h3>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-3">
              A four-stage calibration pipeline (Detect → Diagnose → Correct → Validate) that fixes overconfident and pseudo-precise LLM outputs. <strong class="text-[var(--color-ink)]">+0.75 UCS</strong> improvement at ~$0.001/correction.
            </p>
            <a href="/research/building-trustworthy-ai/checkmycoach/" class="link-arrow">CheckMyCoach →</a>
          </div>

          <!-- Layer 4: Adaptation -->
          <div class="card group overflow-hidden">
            <img src="/images/projects/caltrust-hero.png" alt="" class="w-full h-28 object-cover" style="margin:-1.5rem -1.5rem 1rem -1.5rem; width:calc(100% + 3rem); max-width:none" loading="lazy" />
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-gold-subtle)] flex items-center justify-center text-[var(--color-gold)] font-mono text-[0.55rem] font-bold">04</span>
              <span class="font-mono text-[0.55rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Adaptation</span>
            </div>
            <h3 class="text-[1.05rem] mb-2">CalTrust</h3>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-3">
              A LinUCB contextual bandit that selects the right calibration intervention per user. <strong class="text-[var(--color-ink)]">AUC 0.70</strong> trust predictor, 19,200 simulation trials. Learn when not to intervene.
            </p>
            <a href="/research/understanding-human-trust/caltrust/" class="link-arrow">CalTrust →</a>
          </div>

          <!-- Layer 5: Infrastructure -->
          <div class="card group">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-6 h-6 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center text-[var(--color-secondary)] font-mono text-[0.55rem] font-bold">05</span>
              <span class="font-mono text-[0.55rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Infrastructure</span>
            </div>
            <h3 class="text-[1.05rem] mb-2">Knowledge Compiler + InteractionKit</h3>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed mb-3">
              <strong class="text-[var(--color-ink)]">Knowledge Compiler</strong>: 3,904 structured objects from ACSM + NSCA textbooks for grounding LLM claims. <strong class="text-[var(--color-ink)]">InteractionKit</strong> (active): a versioned schema and platform so trust calibration experiments produce mergeable data across labs.
            </p>
            <a href="/research/building-trustworthy-ai/interactionkit/" class="link-arrow">InteractionKit →</a>
          </div>
        </div>
      </section>

      <!-- FEATURED PUBLICATIONS -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-7 h-7 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center text-[var(--color-secondary)] font-mono text-[0.65rem] font-bold">02</span>
          <span class="font-mono text-[0.6rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Publications</span>
        </div>
        <h2 class="text-[1.6rem] mb-6">Featured Papers</h2>

        <div class="space-y-4">
          <a href="/publications/#checkmycoach-paper" class="card group block">
            <div class="flex items-center gap-3 mb-3">
              <span class="badge badge-under-review">Under Review</span>
              <span class="font-mono text-[0.55rem] text-[var(--color-text-muted)]">CSCW 2027</span>
            </div>
            <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors mb-1">
              From Precision Illusion to Calibration Intervention
            </h3>
            <p class="font-mono text-[0.6rem] text-[var(--color-text-dim)] mb-2">Guo, 2026</p>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed">
              LLM calibration framework + CheckMyCoach pipeline for correcting uncertainty expression in fitness coaching.
            </p>
          </a>

          <a href="/publications/#fitcalib-bench-paper" class="card group block">
            <div class="flex items-center gap-3 mb-3">
              <span class="badge badge-published">In Preparation</span>
            </div>
            <h3 class="font-display text-[1.05rem] text-[var(--color-ink)] group-hover:text-[var(--color-primary)] transition-colors mb-1">
              MaxFitCalib-Bench: A Benchmark for LLM Calibration
            </h3>
            <p class="font-mono text-[0.6rem] text-[var(--color-text-dim)] mb-2">Guo, 2026</p>
            <p class="font-sans text-sm text-[var(--color-text-dim)] leading-relaxed">
              126-question benchmark revealing the precision illusion in LLM fitness advice.
            </p>
          </a>
        </div>
      </section>

      <!-- RECENT UPDATES -->
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-7 h-7 rounded-full bg-[var(--color-gold-subtle)] flex items-center justify-center text-[var(--color-gold)] font-mono text-[0.65rem] font-bold">03</span>
          <span class="font-mono text-[0.6rem] font-semibold text-[var(--color-muted)] uppercase tracking-wider">Activity</span>
        </div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-[1.6rem]">Recent Updates</h2>
          <a href="/blog/" class="link-arrow">All posts —?/a>
        </div>

        <div class="bg-[var(--color-surface)] rounded-xl border border-[var(--color-rule-light)] p-1">
                    <div class="log-item px-4 py-3">
            <span class="log-date">Jul 11</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">arXiv: Precision Illusion methodology paper uploaded (cs.CL)</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 11</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]"><a href="/demo/checkmycoach/" class="link-arrow">CheckMyCoach Interactive Demo</a> live — M1-M4 pipeline visualization</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 10</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">Website v2: CV, Research Notes, 404, robots.txt online</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 9</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">Knowledge Compiler & PI Discovery project pages live</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 8</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">CheckMyCoach & CalTrust pushed to GitHub</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 3</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">Expanded discussion w/ dual-process theory framework</p>
          </div>
          <div class="log-item px-4 py-3">
            <span class="log-date">Jul 2</span>
            <div class="log-dot"></div>
            <p class="font-sans text-sm text-[var(--color-text-dim)]">CalTrust: XGBoost AUC 0.70, RMSE 1.04</p>
          </div>
        </div>
      </section>

    </div>

  </div>
</div>

</BaseLayout>
