---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Projects" description="Research projects — Baixin Guo">
  <div class="container-content py-16">
    <div class="max-w-3xl">

      <span class="section-label mb-4">Projects</span>
      <h1 class="mb-4">Research Projects</h1>
      <p class="text-sm text-[var(--color-text-dim)] mb-10 max-w-lg">
        From defining the precision illusion to building infrastructure for reproducible experiments — six projects forming a five-layer research stack.
      </p>

      <!-- Project 1: MaxFitCalib-Bench -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center text-[var(--color-secondary)] font-mono text-[0.55rem] font-bold">01</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Diagnose</span>
          <span class="badge badge-published">In Preparation</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">MaxFitCalib-Bench</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">A benchmark for evaluating LLM calibration in fitness advice — 126 expert-crafted questions revealing the precision illusion.</p>

        <!-- Mini data table -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">126</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Questions</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">8</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Categories</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">6.3%</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Pseudo-precise</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">48%</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Session risk</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">LLM Evaluation</span>
          <span class="badge text-[0.55rem]">Calibration</span>
          <span class="badge text-[0.55rem]">Fitness AI</span>
          <span class="badge text-[0.55rem]">ACSM Guidelines</span>
        </div>

        <a href="/research/measuring-ai-reliability/fitcalib-bench/" class="link-arrow">View project details →</a>
      </div>

      <!-- Project 2: CheckMyCoach -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.55rem] font-bold">02</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Build</span>
          <span class="badge badge-under-review">Under Review</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">CheckMyCoach</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">A four-stage calibration pipeline that detects, diagnoses, and corrects overconfident and pseudo-precise LLM outputs in real time.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">+0.75</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">UCS Improvement</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">$0.001</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Per Correction</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">4</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Pipeline Stages</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">44+</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Passing Tests</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">LLM Pipeline</span>
          <span class="badge text-[0.55rem]">Calibration</span>
          <span class="badge text-[0.55rem]">GPT-4o-mini</span>
          <span class="badge text-[0.55rem]">AI Safety</span>
        </div>

        <a href="/research/building-trustworthy-ai/checkmycoach/" class="link-arrow">View project details →</a>
      </div>

      <!-- Project 2b: Knowledge Compiler -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-primary-subtle)] flex items-center justify-center text-[var(--color-primary)] font-mono text-[0.55rem] font-bold">KB</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Build</span>
          <span class="badge badge-published">Published</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">Knowledge Compiler</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">Convert authoritative textbooks into reusable structured knowledge — 2,306 objects from ACSM, 1,598 from NSCA for grounding LLM claims.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">2,306</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">ACSM Objects</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">1,598</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">NSCA Objects</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">14</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Ontology Types</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">91.2%</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Accuracy</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">Knowledge Extraction</span>
          <span class="badge text-[0.55rem]">LLM Grounding</span>
          <span class="badge text-[0.55rem]">Textbook NLP</span>
          <span class="badge text-[0.55rem]">Pydantic</span>
        </div>

        <a href="/research/building-trustworthy-ai/knowledge-compiler/" class="link-arrow">View project details →</a>
      </div>

      <!-- Project 3: CalTrust -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-gold-subtle)] flex items-center justify-center text-[var(--color-gold)] font-mono text-[0.55rem] font-bold">03</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Adapt</span>
          <span class="badge badge-gold">In Development</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">CalTrust</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">An adaptive trust calibration system using LinUCB contextual bandits to select the right intervention for each user and context.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">0.70</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">AUC Score</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">1.04</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">RMSE</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">19.2K</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Trials</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">4</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Interventions</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">Contextual Bandit</span>
          <span class="badge text-[0.55rem]">XGBoost</span>
          <span class="badge text-[0.55rem]">LinUCB</span>
          <span class="badge text-[0.55rem]">HCI</span>
        </div>

        <a href="/research/understanding-human-trust/caltrust/" class="link-arrow">View project details →</a>
      </div>

      <!-- Project 4: PI Discovery -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-gold-subtle)] flex items-center justify-center text-[var(--color-gold)] font-mono text-[0.55rem] font-bold">PI</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Tool</span>
          <span class="badge badge-gold">In Development</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">PI Discovery Engine</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">Search Semantic Scholar and OpenAlex to find investigators by research topic, with ranked PI cards and outreach tracking.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">2</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">API Sources</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">7</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Contact Stages</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">∞</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Topics</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">Web</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Streamlit App</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">Semantic Scholar</span>
          <span class="badge text-[0.55rem]">OpenAlex</span>
          <span class="badge text-[0.55rem]">Streamlit</span>
          <span class="badge text-[0.55rem]">RA Search</span>
        </div>

        <a href="/research/building-trustworthy-ai/pi-discovery/" class="link-arrow">View project details →</a>
      </div>

      <!-- Project 5: InteractionKit -->
      <div class="card mb-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-7 h-7 rounded-full bg-[var(--color-secondary-subtle)] flex items-center justify-center text-[var(--color-secondary)] font-mono text-[0.55rem] font-bold">IK</span>
          <span class="font-mono text-[0.6rem] text-[var(--color-muted)] uppercase tracking-wider">Infrastructure</span>
          <span class="badge badge-gold">In Development</span>
        </div>
        <h2 class="text-[1.3rem] mb-2">InteractionKit</h2>
        <p class="text-sm text-[var(--color-text-dim)] mb-3">A versioned log schema and experiment platform so trust calibration experiments produce mergeable data across labs.</p>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">14</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Schema Columns</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">v0.3</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Schema Version</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">N≥120</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Pilot Size</div>
          </div>
          <div class="bg-[var(--color-page-alt)] rounded-lg p-2.5 text-center">
            <div class="font-display text-lg text-[var(--color-ink)]">Pilot</div>
            <div class="text-[0.55rem] font-mono text-[var(--color-text-muted)] uppercase">Status</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-1.5 mb-4">
          <span class="badge text-[0.55rem]">Experiment Platform</span>
          <span class="badge text-[0.55rem]">Trust Calibration</span>
          <span class="badge text-[0.55rem]">Open Science</span>
          <span class="badge text-[0.55rem]">Prolific</span>
        </div>

        <a href="/research/building-trustworthy-ai/interactionkit/" class="link-arrow">View project details →</a>
      </div>

      <!-- Research arc visual -->
      <div class="card-static mt-8 bg-[var(--color-page-warm)] text-center py-6">
        <p class="font-mono text-[0.65rem] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">The Big Picture</p>
        <p class="text-sm text-[var(--color-text-dim)] max-w-md mx-auto">
          These six projects form a complete research stack: <strong class="text-[var(--color-ink)]">theory → measure → intervene → adapt → infrastructure</strong>. Together they represent a full-stack approach to understanding and fixing how AI communicates uncertainty.
        </p>
      </div>

    </div>
  </div>
</BaseLayout>
