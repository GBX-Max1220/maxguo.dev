---
const currentPath = Astro.url.pathname;
const isActive = (href) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const pages = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/publications/', label: 'Publications' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 bg-[var(--color-page)]/90 backdrop-blur-lg border-b border-[var(--color-rule-light)]" aria-label="Main navigation">
  <div class="container-content flex items-center justify-between h-14">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <span class="w-7 h-7 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-white text-[0.7rem] font-mono font-bold transition-transform group-hover:scale-105">M</span>
      <span class="font-display font-bold text-base text-[var(--color-ink)] tracking-tight">
        Max<span class="text-[var(--color-primary)]">.</span>Guo
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1.5">
      {
        pages.map((p) => (
          <a
            href={p.href}
            class={`
              px-4 py-2 text-[0.75rem] rounded-md transition-all duration-150 font-sans font-medium uppercase tracking-wider
              ${isActive(p.href)
                ? 'text-[var(--color-primary)] bg-[var(--color-primary-subtle)]'
                : 'text-[var(--color-text-dim)] hover:text-[var(--color-ink)] hover:bg-[var(--color-surface-hover)]'
              }
            `}
          >
            {p.label}
          </a>
        ))
      }
    </div>

    <!-- Mobile nav toggle (simple inline for now) -->
    <details class="sm:hidden relative">
      <summary class="list-none px-2 py-1 rounded cursor-pointer text-[var(--color-text-dim)] hover:text-[var(--color-ink)]" aria-label="Toggle navigation">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="5" x2="15" y2="5"/>
          <line x1="3" y1="9" x2="15" y2="9"/>
          <line x1="3" y1="13" x2="15" y2="13"/>
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-1 w-44 bg-[var(--color-surface)] border border-[var(--color-rule)] rounded-lg shadow-elevated py-2">
        {
          pages.map((p) => (
            <a
              href={p.href}
              class={`
                block px-4 py-2 text-sm transition-colors
                ${isActive(p.href)
                  ? 'text-[var(--color-primary)] bg-[var(--color-primary-subtle)] font-medium'
                  : 'text-[var(--color-text-dim)] hover:bg-[var(--color-surface-hover)]'
                }
              `}
            >
              {p.label}
            </a>
          ))
        }
      </div>
    </details>
  </div>
</nav>
